<Window x:Class="gymTracker.CreateWorkout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gymTracker"
        mc:Ignorable="d"
        Title="CreateWorkout"
        Height="844"
        Width="390"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>

    </Window.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource HeaderBar}">
            <Button x:Name="menuBackBtn"
                    Content="Back"
                    Style="{StaticResource WhiteRoundedButton}"
                    Width="70"
                    Height="40"
                    Margin="20,15,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="menuBackBtn_Click" />
        </Border>

        <Grid Grid.Row="1"
              Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="workoutNameTbx"
                     Grid.Column="0"
                     Style="{StaticResource PinkTextBox}"
                     Tag="Enter workout name..."
                     Margin="0,0,10,0"
                     Height="45"
                     VerticalAlignment="Center"
                     GotFocus="workoutNameTbx_GotFocus"
                     LostFocus="workoutNameTbx_LostFocus" />

            <Button x:Name="saveBtn"
                    Grid.Column="1"
                    Style="{StaticResource PinkRoundedButton}"
                    Content="Save"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Click="saveBtn_Click" />
        </Grid>

        <StackPanel Grid.Row="2"
                    Margin="20,0,20,10">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="75" />
                    <ColumnDefinition Width="75" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="exerciseSearchTbx"
                         Grid.Column="0"
                         Style="{StaticResource PinkTextBox}"
                         Tag="Search..."
                         Margin="0,0,5,0"
                         Width="Auto"
                         GotFocus="exerciseSearchTbx_GotFocus"
                         LostFocus="exerciseSearchTbx_LostFocus"
                         TextChanged="exerciseSearchTbx_TextChanged" />

                <TextBox x:Name="setsTbx"
                         Grid.Column="1"
                         Style="{StaticResource PinkTextBox}"
                         Tag="Sets"
                         Width="Auto"
                         Margin="0,0,5,0"
                         HorizontalContentAlignment="Center" />

                <TextBox x:Name="repsTbx"
                         Grid.Column="2"
                         Style="{StaticResource PinkTextBox}"
                         Tag="Reps"
                         Width="Auto"
                         HorizontalContentAlignment="Center" />
            </Grid>

            <Button x:Name="addExerciseBtn"
                    Style="{StaticResource PinkRoundedButton}"
                    Content="Add Exercise"
                    Height="45"
                    Margin="0,0,0,0"
                    Click="addExerciseBtn_Click" />
        </StackPanel>

        <ListBox x:Name="exercisesLBx"
                 Grid.Row="3"
                 Margin="20,0,20,0"
                 VerticalAlignment="Top"
                 MaxHeight="200"
                 Panel.ZIndex="10"
                 Visibility="Collapsed">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding"
                            Value="10" />
                    <Setter Property="Background"
                            Value="#F0F0F0" />
                    <Setter Property="Margin"
                            Value="0,1" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Grid Grid.Row="3"
              Margin="20,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label Content="Current Workout:"
                   FontWeight="Bold"
                   Foreground="{StaticResource PinkBrush}" />
            <ListBox x:Name="addedExercisesLBx"
                     Grid.Row="1"
                     Margin="0,5,0,0" />
        </Grid>
    </Grid>
</Window>