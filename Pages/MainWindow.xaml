<Window x:Class="gymTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gymTracker"
        mc:Ignorable="d"
        Title="MainWindow" Height="844" Width="390" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PinkBrush" Color="#EFA2FA"/>
        <!--Styling pink buttons-->
        <Style x:Key="PinkRoundedButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PinkBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--styling white buttons-->
        <Style x:Key="WhiteRoundedButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PinkBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderBrush" Value="{StaticResource PinkBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- pink header bar -->
        <Border Background="{StaticResource PinkBrush}"
            Height="70"
            VerticalAlignment="Top"/>

        <!-- Big button -->
        <Button Style="{StaticResource PinkRoundedButton}"
            Content="Todays Workout"
            HorizontalAlignment="Center"
            Margin="0,160,0,0"
            VerticalAlignment="Top"
            Height="100"
            Width="330"
            FontSize="24"
            />
        <Button Style="{StaticResource WhiteRoundedButton}"
            Content="Create Workout" 
            HorizontalAlignment="Center" 
            Margin="0,270,0,0" 
            VerticalAlignment="Top" 
            Height="55" 
            Width="260"
            FontSize="20"
            />
        <Button Style="{StaticResource WhiteRoundedButton}"
            Content="Saved Routines" 
            HorizontalAlignment="Center" 
            Margin="0,340,0,0" 
            VerticalAlignment="Top" 
            Height="55" 
            Width="260"
            FontSize="20"
            />
        <Button Style="{StaticResource WhiteRoundedButton}"
            Content="Past Workouts" 
            HorizontalAlignment="Center" 
            Margin="0,410,0,0" 
            VerticalAlignment="Top" 
            Height="40" 
            Width="200"
            FontSize="20"
            />
        <Button x:Name="menuBackBtn" Style="{StaticResource PinkRoundedButton}"
            Content="Back" 
            HorizontalAlignment="Center" 
            Margin="0,740,0,0" 
            VerticalAlignment="Top" 
            Height="40" 
            Width="200"
            FontSize="20" 
            Click="menuBackBtn_Click"/>

    </Grid>
</Window>
