<Window x:Class="gymTracker.Pages.LoginScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gymTracker.Pages"
        mc:Ignorable="d"
        Title="LoginScreen" Height="844" Width="390" WindowStartupLocation="CenterScreen">
    <Window.Resources>

        <!-- Pink colour for reuse -->
        <SolidColorBrush x:Key="PinkBrush" Color="#EFA2FA"/>

        <!-- TextBox with pink border + rounded corners -->
        <Style x:Key="PinkTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PinkBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!-- Background + border -->
                            <Border CornerRadius="8"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"/>

                            <!-- Actual text input -->
                            <ScrollViewer x:Name="PART_ContentHost"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center"/>

                            <!-- Placeholder -->
                            <TextBlock Text="{TemplateBinding Tag}"
                           Foreground="#888"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- PasswordBox with pink border + rounded corners -->
        <Style x:Key="PinkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PinkBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="8"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PinkRoundedButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PinkBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <!--this is the content of the button-->
                            <ContentPresenter   HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>

    <Grid Background="White">

        <!-- Pink header bar -->
        <Border Background="{StaticResource PinkBrush}"
            Height="70"
            VerticalAlignment="Top"/>

        <!-- Username -->
        <TextBox x:Name="usernameTbx"
             Style="{StaticResource PinkTextBox}"
             Tag="Enter username"
             HorizontalAlignment="Center"
             Margin="0,232,0,0"
             VerticalAlignment="Top"
             Width="270"
             Height="50" 
             GotFocus="usernameTbx_GotFocus" 
             LostFocus="usernameTbx_LostFocus" />

        <!-- Password -->
        <PasswordBox x:Name="passwordPbx"
            Style="{StaticResource PinkPasswordBox}"
            Tag="Enter password"
            HorizontalAlignment="Center"
            Margin="0,315,0,0"
            VerticalAlignment="Top"
            Width="270"
            Height="50"/>

        <!-- Login button -->
        <Button x:Name="loginBtn"
            Content="Log In"
            HorizontalAlignment="Center"
            Margin="0,414,0,0"
            VerticalAlignment="Top"
            Height="43"
            Width="145"
            Style="{StaticResource PinkRoundedButton}"
            Click="loginBtn_Click"/>

    </Grid>
</Window>
