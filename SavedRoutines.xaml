<Window x:Class="gymTracker.SavedRoutines"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gymTracker"
        mc:Ignorable="d"
        Title="SavedRoutines"
        Height="844"
        Width="399"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource HeaderBar}">
            <Button x:Name="savedRoutinesBackBtn"
                    Content="Back"
                    Style="{StaticResource WhiteRoundedButton}"
                    Width="70"
                    Height="40"
                    Margin="20,15,0,0"
                    HorizontalAlignment="Left"
                    Click="savedRoutinesBackBtn_Click" />
        </Border>

        <Button x:Name="deleteBtn"
                Grid.Row="1"
                Content="Delete Selected Routine"
                Style="{StaticResource PinkRoundedButton}"
                Height="45"
                Margin="20,20,20,10"
                FontSize="16"
                FontWeight="Bold"
                Click="deleteBtn_Click" />

        <Grid Grid.Row="2"
              Margin="20,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Label Content="Saved Routines History:"
                   FontWeight="Bold"
                   Foreground="{StaticResource PinkBrush}" />

            <ListBox x:Name="routinesLBx"
                     Grid.Row="1"
                     Margin="0,5,0,0" />
        </Grid>
    </Grid>
</Window>